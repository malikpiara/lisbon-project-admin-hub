# Get from Google Cloud Console: APIs & Services → Credentials.
# Restrict to Google Calendar API only. See README for full setup.
GOOGLE_CALENDAR_API_KEY=

# Calendar ID from the calendar's Settings → Integrate calendar.
# The calendar must have "Make available to public" enabled.
GOOGLE_CALENDAR_ID=

# ─────────────────────────────────────────────────────────────────────────────
# CMS evaluation (Sanity + Payload run side by side). See docs/CMS-EVALUATION.md.
# ─────────────────────────────────────────────────────────────────────────────

# Sanity — from sanity.io/manage after `npx sanity init`.
# NEXT_PUBLIC_* are needed in the browser (the embedded Studio at /studio).
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2026-06-01
# Editor token (sanity.io/manage → API → Tokens). Only used by `pnpm seed:sanity`.
SANITY_API_WRITE_TOKEN=
# Optional read token, for previewing drafts.
SANITY_API_READ_TOKEN=

# Payload — admin at /cms-admin, REST/GraphQL under /api.
# Generate a long random secret, e.g. `openssl rand -hex 32`.
PAYLOAD_SECRET=
# SQLite by default (zero external services). Swap for a Postgres URL to use
# @payloadcms/db-postgres instead — see docs/CMS-EVALUATION.md.
DATABASE_URI=file:./payload.db
