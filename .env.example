# ─────────────────────────────────────────────────────────────────────────────
# Site URL — canonical public origin (SEO)
# ─────────────────────────────────────────────────────────────────────────────
# Drives metadataBase, canonical URLs, sitemap.xml, robots.txt and JSON-LD
# (lib/site.ts). No trailing slash. Falls back to https://lp.lisboaux.com when
# unset; set this to the real deployed origin in each environment.
NEXT_PUBLIC_SITE_URL=https://lp.lisboaux.com

# ─────────────────────────────────────────────────────────────────────────────
# Google Calendar (public /calendar feed)
# ─────────────────────────────────────────────────────────────────────────────
# Get from Google Cloud Console: APIs & Services → Credentials.
# Restrict to the Google Calendar API only. See README for full setup.
GOOGLE_CALENDAR_API_KEY=
# Calendar ID from the calendar's Settings → Integrate calendar.
# The calendar must have "Make available to public" enabled.
GOOGLE_CALENDAR_ID=

# ─────────────────────────────────────────────────────────────────────────────
# Payload CMS — admin at /cms-admin, REST/GraphQL under /api.
# Runs on Supabase Postgres (the @payloadcms/db-postgres adapter).
# ─────────────────────────────────────────────────────────────────────────────
# A long random secret — generate with: openssl rand -hex 32
PAYLOAD_SECRET=

# Postgres connection string (Supabase). From the Supabase dashboard → Connect.
# Pick the endpoint by workload (this choice bit us — see docs/RELEASE-CHECKLIST §3):
#   • Deployed app on Vercel  → TRANSACTION POOLER, port 6543. Transaction mode
#     multiplexes many short-lived serverless clients over a few real connections,
#     so there's no client-count ceiling. Keep DATABASE_POOL_MAX small — the pooler
#     does the real pooling. Payload/Drizzle/pg use no persistent prepared
#     statements, so no `?pgbouncer=true` flag is needed (verified reads + writes
#     on prod 2026-07-08). Reachable from Vercel over IPv4 — the "IPv6 by default"
#     notice does NOT require the paid IPv4 add-on.
#       postgresql://postgres.<ref>:<pwd>@aws-0-<region>.pooler.supabase.com:6543/postgres
#   • Local dev / migrations / seed  → SESSION POOLER (5432) or the direct
#     connection. Dev schema-push and `payload migrate` want a sticky session,
#     which transaction mode doesn't provide. (The session pooler caps at ~15
#     clients — fine for one dev process; it's why build-time full SSG prerender,
#     N workers × pool, overran it, so the heavy /services routes use on-demand ISR.)
#       postgresql://postgres.<ref>:<pwd>@aws-0-<region>.pooler.supabase.com:5432/postgres
# To use SQLite/Turso instead: re-add @payloadcms/db-sqlite, swap the adapter in
# payload.config.ts, and set e.g. file:./payload.db (local) or a libsql:// Turso URL.
DATABASE_URI=

# Per-process pg pool size. Small on purpose — the Supabase pooler does the real
# pooling, so a large local pool just holds its slots. Defaults to 3 if unset.
DATABASE_POOL_MAX=3

# Seed credentials — `pnpm seed:payload` creates this admin user if none exists.
PAYLOAD_SEED_EMAIL=admin@example.com
PAYLOAD_SEED_PASSWORD=changeme123

# ─────────────────────────────────────────────────────────────────────────────
# PostHog product analytics (EU cloud).
# ─────────────────────────────────────────────────────────────────────────────
# Create the "Lisbon Project" project in the PostHog dashboard, then paste its
# Project API key here (Settings → Project; starts with `phc_`). Leave the key
# empty to disable analytics entirely (the SDK is a no-op without it).
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com

# Server-side reads for the team-only /admin/insights dashboard.
# The phc_ key above can only WRITE events (/capture/). Reading them back for the
# dashboard needs a *Personal API Key*: PostHog → Settings → User → Personal API
# keys, scoped to `query:read` for this project (starts with `phx_`). Leave empty
# and the dashboard falls back to sample data. Server-only — never NEXT_PUBLIC_*.
POSTHOG_PERSONAL_API_KEY=
# Numeric project id (PostHog → Settings → Project). Defaults to the Lisbon
# Project id (208396) if unset.
POSTHOG_PROJECT_ID=208396
# Query API host. Auto-derived from NEXT_PUBLIC_POSTHOG_HOST (eu.i.posthog.com →
# eu.posthog.com); only set to override for self-host / a reverse proxy.
# POSTHOG_API_HOST=https://eu.posthog.com

# Shared secret for the Zapier → PostHog chatbot transcript webhook
# (/webhooks/chatbot-log). Must match the `Authorization: Bearer …` header the
# Zap sends. Leave empty and the endpoint refuses all requests (503). See
# docs/ANALYTICS.md → "Chatbot conversation logging".
CHATBOT_LOG_SECRET=

# ─────────────────────────────────────────────────────────────────────────────
# MailerLite (newsletter — sending platform kept after the site migration).
# ─────────────────────────────────────────────────────────────────────────────
# The footer signup form (components/site/newsletter-form.jsx) upserts
# subscribers into MailerLite. PARKED until this key is set: while empty, signups
# are captured in the Payload `subscribers` table instead (Supabase) so none are
# lost — import those into MailerLite once it's live. API key: MailerLite →
# Integrations → API → generate a token.
MAILERLITE_API_KEY=
# Optional. Group (list) to file signups into. MailerLite → Subscribers → Groups
# → open the group; the id is in the URL. Leave empty to add to the account only.
MAILERLITE_GROUP_ID=
